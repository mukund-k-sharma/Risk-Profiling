# ============================================================
# .gitignore — Real-Time User Risk Profiling
# ============================================================

# ─── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.eggs/
.venv/
venv/
env/

# ─── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Data (large files — use LFS or download separately) ──
data/
*.parquet
*.parquet.gzip
src/v1/PS_20174392719_1491204439457_log.csv

# ─── Model artifacts (generated, not source) ──────────────
*.pth
*.h5
*.joblib
artifacts/

# ─── Notebook auxiliary outputs ────────────────────────────
notebooks/preprocessor.joblib
notebooks/global_stats.json
notebooks/X_train_sample.csv

# ─── Source-local generated files ──────────────────────────
src/v1/global_stats.json
src/v1/autoencoder_model.pth
src/v1/preprocessor.joblib

# ─── Spark checkpoints ────────────────────────────────────
checkpoint_alerts/
checkpoint_metrics/

# ─── Reports & Dissertation (private/large) ───────────────
reports/BITS_MTech_Dissertation_2023AA05458/
reports/Draft/
reports/submission/*

# ─── Presentations ─────────────────────────────────────────
ppt/*.odp

# ─── Reference papers (copyrighted PDFs) ──────────────────
papers/

# ─── Archives / packages ──────────────────────────────────
*.zip
*.tar.gz
*.rar

# ─── Media (generated screenshots/plots) ──────────────────
*.mp4

# ─── Log files ─────────────────────────────────────────────
*.log

# ─── AI tool configuration (not project source) ───────────
.claude/
.claudeignore
CLAUDE.md

# ─── Legacy / deprecated source files ─────────────────────
src/v1/streaming_app_v[1-4].py
src/v1/dashbaord_debug.py
src/v1/dashboard.py
src/v1/producer_drift_org.py
src/v2/
# ─── Negation: track dissertation PDF ─────────────────────
!reports/submission/2023AA05458.pdf
